/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
        ext.when   = When to run the module.
----------------------------------------------------------------------------------------
*/

// ENSEMBLVEP ANNOTATION
process {
    withName: 'ENSEMBLVEP_DOWNLOAD' {
        ext.args   = { '--AUTO c --CONVERT --NO_BIOPERL --NO_HTSLIB --NO_TEST --NO_UPDATE' }
        publishDir = [
            mode: params.publish_dir_mode,
            path: { params.outdir_vep_cache ? "${params.outdir_vep_cache}/": "${params.outdir}/annotation" }
        ]
    }

    withName: '.*:VCF_ANNOTATE_ENSEMBLVEP_SNP:ENSEMBLVEP_VEP' {
        // Use ext.args to add your specific VEP flags
        ext.args   = { ["--stats_file ${meta.file_name}.vep.summary.html",
                (params.vep_out_format)     ? "--${params.vep_out_format}"                                                                                           : '--vcf',
                (params.vep_custom_args)    ?: ''
            ].join(' ').trim() }

        ext.prefix = { "${meta.file_name}.vep" }
        publishDir = [
            [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/annotation/vep/snv" }
            ]
        ]
    }

    withName: '.*:VCF_ANNOTATE_ENSEMBLVEP_CNV:ENSEMBLVEP_VEP' {
        // Use ext.args to add your specific VEP flags
        ext.args   = { ["--stats_file ${meta.file_name}.vep.summary.html",
                "--max_sv_size 50000000",                        
                (params.vep_out_format)     ? "--${params.vep_out_format}"                                                                                           : '--vcf',
                (params.vep_custom_args)    ?: ''
            ].join(' ').trim() }

        ext.prefix = { "${meta.file_name}.vep" }
        publishDir = [
            [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/annotation/vep/cnv" }
            ]
        ]
    }

    withName: '.*:VCF_ANNOTATE_ENSEMBLVEP_SV:ENSEMBLVEP_VEP' {
        // Use ext.args to add your specific VEP flags
        ext.args   = { ["--stats_file ${meta.file_name}.vep.summary.html",
                "--max_sv_size 50000000",
                (params.vep_out_format)     ? "--${params.vep_out_format}"                                                                                           : '--vcf',
                (params.vep_custom_args)    ?: ''
            ].join(' ').trim() }

        ext.prefix = { "${meta.file_name}.vep" }
        publishDir = [
            [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/annotation/vep/sv" }
            ]
        ]
    }
}
