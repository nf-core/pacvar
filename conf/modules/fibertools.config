process {
    withName: '.*:BAM_M6A_ADDNUCLEOSOMES_FIBERTOOLS:.*' {
        publishDir = [
            path: { "${params.outdir}/fibertools" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:BAM_M6A_ADDNUCLEOSOMES_FIBERTOOLS:FIBERTOOLSRS_PREDICTM6A' {
        ext.prefix = { "${meta.file_name}.m6A" }
    }

    withName: '.*:BAM_M6A_ADDNUCLEOSOMES_FIBERTOOLS:FIBERTOOLSRS_ADDNUCLEOSOMES' {
        ext.prefix = { "${meta.file_name}.nucleosomes" }
    }

    withName: '.*:BAM_M6A_ADDNUCLEOSOMES_FIBERTOOLS:FIBERTOOLSRS_EXTRACT_NUC' {
        ext.prefix = { "${meta.file_name}.nucleosomes" }
    }

    withName: '.*:BAM_M6A_ADDNUCLEOSOMES_FIBERTOOLS:FIBERTOOLSRS_EXTRACT_M6A' {
        ext.prefix = { "${meta.file_name}.m6A" }
    }
}
