/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/pacvario -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/


process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '6.h'
    ]

    withName: 'SAWFISH_DISCOVER' {
        ext.args = '--cov-regex "."'
    }

    withName: 'HIFICNV' {
        ext.args = '--cov-regex "."'
    }
}

params {
    config_profile_name         = 'Test profile'
    config_profile_description  = 'Minimal test dataset to check pipeline function for pure-trgt workflow'

    input                       = params.pipelines_testdata_base_path + 'pacbio_data/samplesheet_pb_downsampled.csv'
    fasta                       = params.pipelines_testdata_base_path + 'pacbio_data/genome3.fasta'
    fasta_fai                   = params.pipelines_testdata_base_path + 'pacbio_data/genome3.fasta.fai' // deepvariant requires fai
    dict                        = ''
    dbsnp                       = ''
    dbsnp_tbi                   = ''
    intervals                   = ''
    expected_cn                 = ''
    cnv_excluded_regions        = ''
    skip_demultiplexing         = true
    workflow                    = 'wgs'
    skip_snp                    = false     // resulted VCF will used as MAF input for HiFiCNV and sawfish
    snv_caller                  = 'deepvariant'
    skip_sv                     = false
    sv_caller                   = 'sawfish' // sawfish will also run cnv calling
    skip_phase                  = false
    skip_cpg                    = true      // no need to test it here
    skip_hificnv                = false     // test HiFiCNV
    skip_ensemblvep             = true      // Skip VEP annotation to save time/bandwidth for ~23GB cache staging
}
